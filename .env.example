# Chrome Profile Configuration
# To find your profile path, open Chrome and go to chrome://version/
# Look for "Profile Path" — use the parent "User Data" folder below
CHROME_USER_DATA_DIR=C:\Users\prade\AppData\Local\Google\Chrome\User Data
CHROME_PROFILE=Default

# Flask Configuration
FLASK_SECRET_KEY=your-secret-key-change-this
FLASK_PORT=5000

# Browser Automation
CHROME_DEBUG_PORT=9222
AI_RESPONSE_TIMEOUT=120
